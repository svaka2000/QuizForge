# QuizForge — Root Environment Variables
# Copy this file to .env and fill in your values before running docker-compose.
# Generate SECRET_KEY with: openssl rand -hex 32

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-secure-random-string-min-32-chars

# ── Database (docker-compose uses PostgreSQL) ─────────────────────────────────
POSTGRES_PASSWORD=changeme

# ── AI (leave blank to use built-in MockGenerator) ───────────────────────────
ANTHROPIC_API_KEY=

# ── Stripe (leave blank to disable billing) ───────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_MONTHLY=price_...

# ── URLs ──────────────────────────────────────────────────────────────────────
# Public domain (used for CORS and the frontend NEXT_PUBLIC_API_URL)
FRONTEND_URL=https://yourdomain.com

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com

# ── Rate limits ───────────────────────────────────────────────────────────────
FREE_TIER_DAILY_LIMIT=3
PRO_TIER_DAILY_LIMIT=100

# ─────────────────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT ONLY (not needed for docker-compose)
# ─────────────────────────────────────────────────────────────────────────────
# Set in backend/.env for local uvicorn runs:
#   DATABASE_URL=sqlite:///./quizforge.db
#   DEBUG=true
#   ENVIRONMENT=development
#
# Set in frontend/.env.local for local Next.js runs:
#   NEXT_PUBLIC_API_URL=http://localhost:8000
