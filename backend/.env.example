# QuizForge Backend Environment Variables
# Copy this file to .env and fill in your values

# App
APP_NAME=QuizForge
DEBUG=false
ENVIRONMENT=development

# Database
DATABASE_URL=sqlite:///./quizforge.db

# Security — generate with: openssl rand -hex 32
SECRET_KEY=change-this-to-a-random-secret-key-32-chars-min

# AI (optional — app works without this via MockGenerator)
ANTHROPIC_API_KEY=

# Stripe (optional — for subscription features)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_MONTHLY=price_...

# Usage Limits
FREE_TIER_DAILY_LIMIT=3
PRO_TIER_DAILY_LIMIT=100

# Admin
ADMIN_EMAIL=admin@quizforge.io

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
